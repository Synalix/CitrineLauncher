<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CitrineLauncher.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <!-- Improvement #20: defined once here instead of copy-pasted in every AXAML file -->
        <LinearGradientBrush x:Key="CitrineBrush" StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0.0" Color="#E2B007"/>
            <GradientStop Offset="1.0" Color="#9ACD32"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CitrineHover" StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0.0" Color="#FFD84D"/>
            <GradientStop Offset="1.0" Color="#BCE24A"/>
        </LinearGradientBrush>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme/>
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="{StaticResource CitrineBrush}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Button.accent:pointerover">
            <Setter Property="Background" Value="{StaticResource CitrineHover}"/>
        </Style>
        <Style Selector="Button.accent:disabled">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>
    </Application.Styles>
</Application>
