<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:handlers="clr-namespace:CitrineLauncher.Handlers"
             x:Class="CitrineLauncher.SettingsPanel"
             x:DataType="handlers:Settings"
             Width="760"
             MaxHeight="520"
             Background="#1A1A1A"
             CornerRadius="16"
             BorderBrush="#2A2A2A"
             BorderThickness="1">

    <UserControl.RenderTransform>
        <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
    </UserControl.RenderTransform>

    <UserControl.Styles>

        <!-- Nav buttons -->
        <Style Selector="Button.nav">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style Selector="Button.nav:pointerover">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Primary action button -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{StaticResource CitrineBrush}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="{StaticResource CitrineHover}"/>
        </Style>
        <Style Selector="Button.primary:disabled">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>

        <!-- Secondary button -->
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Button.secondary:pointerover">
            <Setter Property="Background" Value="#3A3A3A"/>
        </Style>

        <!-- Section cards -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Labels -->
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource CitrineBrush}"/>
            <Setter Property="LetterSpacing" Value="2"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- ComboBox styling -->
        <Style Selector="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource CitrineBrush}"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>

        <!-- ListBox styling -->
        <Style Selector="ListBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- TextBox -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <!-- CheckBox text -->
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
        </Style>

        <!-- Context menu -->
        <Style Selector="MenuItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2A2A2A"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="180, *">

        <!-- Left sidebar -->
        <Border Grid.Column="0" Background="#141414" CornerRadius="16,0,0,16" BorderBrush="#2A2A2A" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto, *, Auto" Margin="12,20,12,16">

                <!-- Logo area -->
                <StackPanel Grid.Row="0" Margin="4,0,0,24" Spacing="2">
                    <TextBlock Text="CITRINE" FontSize="11" FontWeight="Black"
                               Foreground="{StaticResource CitrineBrush}" LetterSpacing="3"/>
                    <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Foreground="White"/>
                </StackPanel>

                <!-- Nav items -->
                <StackPanel Grid.Row="1" Spacing="4">
                    <Button x:Name="GeneralNav" Classes="nav">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Path Data="M12,15.5 A3.5,3.5 0 0 1 8.5,12 A3.5,3.5 0 0 1 12,8.5 A3.5,3.5 0 0 1 15.5,12 A3.5,3.5 0 0 1 12,15.5 Z M19.43,12.97 C19.47,12.65 19.5,12.33 19.5,12 C19.5,11.67 19.47,11.34 19.43,11 L21.54,9.37 C21.73,9.22 21.78,8.95 21.66,8.73 L19.66,5.27 C19.54,5.05 19.27,4.97 19.05,5.05 L16.56,6.05 C16.04,5.65 15.48,5.32 14.87,5.07 L14.49,2.42 C14.46,2.18 14.25,2 14,2 L10,2 C9.75,2 9.54,2.18 9.51,2.42 L9.13,5.07 C8.52,5.32 7.96,5.66 7.44,6.05 L4.95,5.05 C4.72,4.96 4.46,5.05 4.34,5.27 L2.34,8.73 C2.21,8.95 2.27,9.22 2.46,9.37 L4.57,11 C4.53,11.34 4.5,11.67 4.5,12 C4.5,12.33 4.53,12.65 4.57,13 L2.46,14.63 C2.27,14.78 2.21,15.05 2.34,15.27 L4.34,18.73 C4.46,18.95 4.73,19.03 4.95,18.95 L7.44,17.95 C7.96,18.35 8.52,18.68 9.13,18.93 L9.51,21.58 C9.54,21.82 9.75,22 10,22 L14,22 C14.25,22 14.46,21.82 14.49,21.58 L14.87,18.93 C15.48,18.68 16.04,18.34 16.56,17.95 L19.05,18.95 C19.28,19.04 19.54,18.95 19.66,18.73 L21.66,15.27 C21.78,15.05 21.73,14.78 21.54,14.63 Z"
                                  Fill="#AAAAAA" Stretch="Uniform" Width="15" Height="15" VerticalAlignment="Center"/>
                            <TextBlock Text="General" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="AccountsNav" Classes="nav">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Path Data="M12,12 A4,4 0 1 0 12,4 A4,4 0 0 0 12,12 Z M12,14 C7.58,14 4,16.24 4,19 L4,20 L20,20 L20,19 C20,16.24 16.42,14 12,14 Z"
                                  Fill="#AAAAAA" Stretch="Uniform" Width="15" Height="15" VerticalAlignment="Center"/>
                            <TextBlock Text="Accounts" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="AppearanceNav" Classes="nav">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Path Data="M12,3 A9,9 0 1 0 12,21 A9,9 0 0 0 12,3 Z M12,19 A7,7 0 0 1 5,12 A7,7 0 0 1 12,5 L12,19 Z"
                                  Fill="#AAAAAA" Stretch="Uniform" Width="15" Height="15" VerticalAlignment="Center"/>
                            <TextBlock Text="Appearance" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="PerformanceNav" Classes="nav">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Path Data="M13,2.05 L13,4.05 C17.39,4.59 20.5,8.58 19.96,12.97 C19.5,16.61 16.64,19.5 13,19.93 L13,21.93 C18.5,21.38 22.5,16.5 21.95,11 C21.5,6.25 17.73,2.5 13,2.05 Z M11,2.06 C8.04,2.37 5.48,3.83 3.72,6.05 L5.16,7.45 C6.54,5.62 8.44,4.33 11,4.06 L11,2.06 Z M3.67,7.95 A10,10 0 0 0 2.05,11 L4.05,11 C4.24,9.58 4.8,8.27 5.62,7.17 L3.67,7.95 Z M4.06,13 L2.06,13 C2.5,15.32 3.61,17.41 5.18,19.03 L6.62,17.59 C5.38,16.31 4.5,14.73 4.06,13 Z M5.16,19.95 C6.8,21.5 8.87,22.58 11,22.94 L11,20.94 C9.44,20.63 8.01,19.87 6.6,18.53 L5.16,19.95 Z"
                                  Fill="#AAAAAA" Stretch="Uniform" Width="15" Height="15" VerticalAlignment="Center"/>
                            <TextBlock Text="Performance" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Row="2" Text="v1.0.4 Beta" FontSize="10" Opacity="0.3"
                           HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Right content -->
        <Grid Grid.Column="1" Margin="20,16,16,16">

            <!-- Close button -->
            <Button x:Name="CloseButton"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Background="Transparent" BorderThickness="0"
                    Width="28" Height="28" Padding="0" CornerRadius="6">
                <Path Data="M0,0 L12,12 M12,0 L0,12"
                      Stroke="White" StrokeThickness="1.5"
                      Width="12" Height="12" Opacity="0.6"/>
            </Button>

            <ScrollViewer Padding="0,0,8,0" Margin="0,32,0,0">
                <StackPanel Spacing="4">

                    <!-- GENERAL SECTION -->
                    <StackPanel x:Name="GeneralSection">
                        <TextBlock Text="GENERAL" Classes="section-title"/>

                        <Border Classes="card">
                            <StackPanel Spacing="16">

                                <!-- Min RAM -->
                                <StackPanel Spacing="6">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBlock Text="Minimum RAM (MB)" Classes="label"/>
                                        <CheckBox x:Name="MinRamCustomCheck" Grid.Column="1"
                                                  Content="Custom" FontSize="12"
                                                  IsChecked="{Binding UseCustomMinRam, Mode=OneTime}"/>
                                    </Grid>
                                    <ComboBox x:Name="MinRamCombo"
                                              ItemsSource="{Binding RamOptions}"
                                              SelectedItem="{Binding MinRam}"
                                              HorizontalAlignment="Stretch"/>
                                    <TextBox x:Name="MinRamTextBox" IsVisible="False"
                                             Text="{Binding MinRam, Mode=OneTime}"
                                             Watermark="e.g. 1024"/>
                                </StackPanel>

                                <!-- Max RAM -->
                                <StackPanel Spacing="6">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBlock Text="Maximum RAM (MB)" Classes="label"/>
                                        <CheckBox x:Name="MaxRamCustomCheck" Grid.Column="1"
                                                  Content="Custom" FontSize="12"
                                                  IsChecked="{Binding UseCustomMaxRam, Mode=OneTime}"/>
                                    </Grid>
                                    <ComboBox x:Name="MaxRamCombo"
                                              ItemsSource="{Binding RamOptions}"
                                              SelectedItem="{Binding MaxRam}"
                                              HorizontalAlignment="Stretch"/>
                                    <TextBox x:Name="MaxRamTextBox" IsVisible="False"
                                             Text="{Binding MaxRam, Mode=OneTime}"
                                             Watermark="e.g. 2048"/>
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ACCOUNTS SECTION -->
                    <StackPanel x:Name="AccountsSection" IsVisible="False">
                        <TextBlock Text="ACCOUNTS" Classes="section-title"/>

                        <Border Classes="card">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="AddMicrosoftButton" Classes="primary"
                                            Content="Add Microsoft"/>
                                    <Button x:Name="AddOfflineButton" Classes="primary"
                                            Content="Add Offline"/>
                                </StackPanel>

                                <ListBox x:Name="AccountsList" MaxHeight="160">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="handlers:Account">
                                            <Border Padding="10,8" Background="#2A2A2A"
                                                    Margin="4,2" CornerRadius="6">
                                                <Grid ColumnDefinitions="*, Auto">
                                                    <TextBlock Text="{Binding Username}"
                                                               VerticalAlignment="Center" FontSize="13"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Type}"
                                                               Foreground="{StaticResource CitrineBrush}"
                                                               FontSize="11" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Edit" Click="EditMenuItem_Click"/>
                                            <MenuItem Header="Delete" Click="DeleteMenuItem_Click"/>
                                        </ContextMenu>
                                    </ListBox.ContextMenu>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- APPEARANCE SECTION -->
                    <StackPanel x:Name="AppearanceSection" IsVisible="False">
                        <TextBlock Text="APPEARANCE" Classes="section-title"/>

                        <Border Classes="card">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Theme" Classes="label"/>
                                    <ComboBox x:Name="ThemeBox" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding ThemeOptions}"
                                              SelectedItem="{Binding Theme}"/>
                                </StackPanel>

                                <CheckBox IsChecked="{Binding ParticlesEnabled}">
                                    <TextBlock Text="Enable particle effects" FontSize="13"/>
                                </CheckBox>

                                <StackPanel Spacing="6">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBlock Text="Particle Density" Classes="label"/>
                                        <TextBlock Grid.Column="1" FontSize="12" Opacity="0.5"
                                                   Text="{Binding ParticleDensity, StringFormat='{}{0}%'}"/>
                                    </Grid>
                                    <Slider Minimum="0" Maximum="100" Value="{Binding ParticleDensity}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- PERFORMANCE SECTION -->
                    <StackPanel x:Name="PerformanceSection" IsVisible="False">
                        <TextBlock Text="PERFORMANCE" Classes="section-title"/>

                        <Border Classes="card">
                            <StackPanel Spacing="10">
                                <!-- Bug fix #23: renamed to match actual behavior -->
                                <CheckBox IsChecked="{Binding MinimizeOnLaunch}">
                                    <TextBlock Text="Minimize launcher when game starts" FontSize="13"/>
                                </CheckBox>
                                <CheckBox IsChecked="{Binding ShowConsole}">
                                    <TextBlock Text="Show Minecraft console window" FontSize="13"/>
                                </CheckBox>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="MINECRAFT FOLDER" Classes="section-title" Margin="0,8,0,10"/>
                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <!-- Bug fix #7: TextBlock for display only, TextBox shown only in edit mode -->
                                <TextBlock x:Name="FolderPathTextBlock" FontSize="12" Opacity="0.7"
                                           TextWrapping="Wrap"/>
                                <TextBox x:Name="FolderPathTextBox" IsVisible="False"
                                         Watermark="Enter path..."/>
                                <Button x:Name="ChangeFolderButton" Classes="secondary"
                                        Content="CHANGE" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
