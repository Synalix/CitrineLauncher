<Window xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:local="clr-namespace:CitrineLauncher"
         x:Class="CitrineLauncher.ModrinthBrowseDialog"
         Title="Browse Modrinth Modpacks"
         Width="640" Height="580"
         WindowStartupLocation="CenterOwner"
         Background="#1E1E1E"
         Foreground="White"
         CanResize="False">

    <Grid Margin="20" RowDefinitions="Auto, Auto, *, Auto, Auto">

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Browse Modrinth Modpacks" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource CitrineBrush}"/>
            <TextBlock Text="Search and download modpacks from Modrinth"
                       FontSize="12" Foreground="#888" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Search bar with filter -->
        <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="0,0,0,12">
            <TextBox x:Name="SearchBox"
                     Grid.Column="0"
                     Watermark="Search modpacks..."
                     Background="#2A2A2A"
                     BorderBrush="#3A3A3A"
                     Padding="12,10"
                     FontSize="14"
                     KeyDown="SearchBox_KeyDown"/>
            <Button x:Name="SearchButton"
                    Grid.Column="1"
                    Content="Search"
                    Width="90" Height="40"
                    Margin="10,0,0,0"
                    Background="{StaticResource CitrineBrush}"
                    Foreground="Black"
                    FontWeight="Bold"
                    CornerRadius="8"
                    Click="SearchButton_Click"/>
        </Grid>

        <!-- Results list -->
        <Border Grid.Row="2" Background="#252525" CornerRadius="8" ClipToBounds="True">
            <ListBox x:Name="ResultsList"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionMode="Single"
                     SelectionChanged="ResultsList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="local:ModrinthResultItem">
                        <Grid ColumnDefinitions="52, *" Margin="8,10,8,10" MinHeight="52">
                            <!-- Icon with placeholder -->
                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="6"
                                    Background="#333" Margin="0,0,12,0">
                                <Image Width="40" Height="40"
                                       Source="{Binding IconBitmap}"
                                       Stretch="UniformToFill"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Border>
                            <!-- Text -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Description}"
                                            FontSize="12"
                                            Foreground="#999"
                                            MaxLines="1"
                                            TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="-"
                                                FontSize="11"
                                                Foreground="#666"/>
                                    <TextBlock Text="•" FontSize="11" Foreground="#555"/>
                                    <TextBlock Text="{Binding DownloadsText}"
                                                FontSize="11"
                                                Foreground="#777"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="4,2"/>
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="#3A3A3A"/>
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#2F2F2F"/>
                    </Style>
                </ListBox.Styles>
            </ListBox>
        </Border>

        <!-- Status / progress -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
            <TextBlock x:Name="StatusText"
                       Foreground="#999"
                       FontSize="12"
                       IsVisible="False"/>
        </StackPanel>

        <!-- Action buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="10" Margin="0,14,0,0">
            <Button Content="Cancel" Width="100" Height="36"
                    Click="CancelButton_Click"
                    Background="#333" Foreground="White" CornerRadius="8"
                    Padding="16,0"/>
            <Button x:Name="ImportButton"
                    Content="Download"
                    Width="100" Height="36"
                    IsEnabled="False"
                    Click="ImportButton_Click"
                    Background="{StaticResource CitrineBrush}"
                    Foreground="Black"
                    FontWeight="Bold"
                    CornerRadius="8"/>
        </StackPanel>

    </Grid>
</Window>
